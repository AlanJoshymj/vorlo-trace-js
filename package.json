{
  "name": "vorlo-trace",
  "version": "0.3.0",
  "description": "AI agent observability SDK \u2014 see exactly why your agent failed, in 30 seconds.",
  "license": "MIT",
  "author": "Alan Joshy <alan@vorlo.dev>",
  "homepage": "https://vorlo.dev",
  "keywords": [
    "ai",
    "agent",
    "observability",
    "debugging",
    "langchain",
    "langchainjs",
    "tracing",
    "llm",
    "mcp",
    "step-replay",
    "vorlo"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.1.0"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "bin": {
    "vorlo-mcp": "./dist/mcp.js"
  }
}
